# Environment Variables
# Copy this file to .env.local and fill in the values

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here


# Cleanup API Key (used to protect the cleanup cron endpoint)
CLEANUP_API_KEY=your-cleanup-api-key-here

# Redis Configuration (e.g. Upstash Redis connection string URL)
REDIS_URL=redis://localhost:6379

# Site URL (used for SEO, canonical URLs, and URL shortener display)
NEXT_PUBLIC_SITE_URL=https://anyformat.in

# Cloudflare Turnstile Bot Protection (using testing keys by default)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Upstash Redis REST (for URL shortener, rate limiting, user tiers)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Razorpay Payment (Standard Checkout)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# Resend Email (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=AnyFormat <noreply@anyformat.rithvikshetty.in>
